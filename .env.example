APP_WORKSPACE_ID=00000000-0000-4000-8000-000000000001

# Server-side provider keys only. Never expose these as NEXT_PUBLIC_*.
OPENAI_API_KEY=
OMNIVOICE_API_KEY=
OMNIVOICE_API_URL=http://localhost:8000
# MuseTalk-compatible lip-sync microservice.
# Local/shared filesystem mode uses POST ${LIPSYNC_API_URL}/generate.
# Kaggle/external mode uses multipart POST ${LIPSYNC_API_URL}/generate-upload and downloads videoUrl.
LIPSYNC_ENGINE=musetalk-v15
LIPSYNC_API_URL=http://localhost:8010
LIPSYNC_API_KEY=
LIPSYNC_TIMEOUT_MS=1800000
LIPSYNC_TRANSFER_MODE=upload
LIPSYNC_DOWNLOADS_DIR=.generated/jobs

# Speech-to-text
STT_PROVIDER=whisper-speed
STT_WHISPER_URL=http://127.0.0.1:8011/transcribe
STT_MODE=fast
STT_MODEL=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=pt
STT_BEAM_SIZE=1
STT_BEST_OF=1
STT_CONDITION_ON_PREVIOUS_TEXT=false

# Microservice configuration (Kaggle/Colab/Server)
MUSETALK_REPO_PATH=/kaggle/working/MuseTalk
MUSETALK_VERSION=v15
MUSETALK_UNET_MODEL_PATH=models/musetalkV15/unet.pth
MUSETALK_UNET_CONFIG=models/musetalkV15/musetalk.json
MUSETALK_OUTPUTS_DIR=/kaggle/working/mrchicken_lipsync_outputs
MUSETALK_TIMEOUT_SECONDS=1800
MUSETALK_REQUIRE_GPU=true
MUSETALK_FFMPEG_PATH=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional yt-dlp authentication for Instagram/TikTok links that require login.
# Prefer YTDLP_COOKIES_PATH for production; YTDLP_COOKIES_FROM_BROWSER is convenient locally.
YTDLP_PATH=
YTDLP_COOKIES_PATH=
YTDLP_COOKIES_FROM_BROWSER=

# Flow & Web Automation (Playwright or Chrome extension)
FLOW_BROWSER_DRIVER=extension
FLOW_HEADLESS=false
FLOW_TIMEOUT=300000
FLOW_DOWNLOAD_PATH=storage/generated/
FLOW_PROFILE_PATH=storage/browser-profile/
FLOW_BROWSER_CHANNEL=chrome
FLOW_ALLOW_PROTECTED_LLM_WEB=false
FLOW_EXTENSION_TOKEN=
FLOW_EXTENSION_TASK_TIMEOUT=300000
FLOW_URL=https://flow.google
FLOW_IMAGE_URL=https://flow.google
FLOW_VIDEO_URL=https://flow.google

# Optional official API fallbacks for prompt optimization.
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

