NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
APP_WORKSPACE_ID=00000000-0000-4000-8000-000000000001

# Server-side provider keys only. Never expose these as NEXT_PUBLIC_*.
OPENAI_API_KEY=
OMNIVOICE_API_KEY=
OMNIVOICE_API_URL=http://localhost:8000
# MuseTalk-compatible lip-sync microservice.
# Next.js sends local/shared filesystem paths to POST ${LIPSYNC_API_URL}/generate.
LIPSYNC_API_URL=http://localhost:8010
LIPSYNC_API_KEY=
LIPSYNC_TIMEOUT_MS=900000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
