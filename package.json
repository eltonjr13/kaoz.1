{
  "name": "ai-ugc-reaction-studio",
  "version": "0.2.12",
  "description": "Kaoz.1 AI content creation studio for Windows",
  "author": "Kaoz.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/eltonjr13/kaoz.1.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --webpack",
    "desktop:dev": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "build": "node scripts/build-next.mjs",
    "desktop:prepare": "node scripts/prepare-desktop-build.mjs && node scripts/prepare-parakeet-runtime.mjs && node scripts/smoke-desktop-standalone.mjs",
    "desktop:smoke": "node scripts/smoke-desktop-standalone.mjs",
    "desktop:build": "npm run build && npm run desktop:prepare && electron-builder --win nsis --publish never",
    "desktop:release": "npm run build && npm run desktop:prepare && electron-builder --win nsis --publish always",
    "desktop:verify-release": "node scripts/verify-update-artifacts.mjs",
    "desktop:dir": "npm run build && npm run desktop:prepare && electron-builder --dir",
    "start": "next start",
    "clean:check": "node scripts/clean-generated.mjs --include-release",
    "clean:caches": "node scripts/clean-generated.mjs --apply --include-release",
    "clean:all-generated": "node scripts/clean-generated.mjs --apply --include-release --include-desktop-runtime",
    "test": "npm run typecheck && npm run test:product-surface && npm run test:chat-context && npm run test:flow-image && npm run test:image-prompt && npm run test:personality && npm run test:memory && npm run test:memory-archive && npm run test:voice-expression && npm run test:tool-safety && npm run test:connectors && npm run test:skills && npm run test:agent-prompt && npm run test:agent-infrastructure && npm run test:agent-capabilities && npm run test:agent-registry && npm run test:artifacts && npm run test:updates && npm run test:desktop && npm run test:speech && npm run test:lipsync && npm run test:build-cleanup",
    "lint": "eslint . --cache --cache-strategy content --concurrency 4 --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:product-surface": "node --no-warnings --test tests/product-surface-retirement.test.mjs",
    "test:chat-context": "node --no-warnings scripts/test-chat-context-leakage.mjs",
    "test:flow-image": "node --no-warnings --test tests/flow-image-contract.test.mjs",
    "test:image-prompt": "node --experimental-strip-types --no-warnings --test tests/image-prompt-engineering.test.ts",
    "test:personality": "node --experimental-strip-types --no-warnings --test tests/agent-personality.test.ts",
    "test:memory": "node --experimental-strip-types --no-warnings --test tests/cognitive-memory.test.ts",
    "test:memory-archive": "node --experimental-strip-types --no-warnings --test tests/conversation-memory.test.ts",
    "test:voice-expression": "node --experimental-strip-types --no-warnings --test tests/agent-voice-expression.test.ts",
    "test:tool-safety": "node --experimental-strip-types --no-warnings --test tests/tool-safety.test.ts",
    "test:connectors": "node --experimental-strip-types --no-warnings --test tests/connectors-core.test.ts tests/discord-inbound.test.ts tests/telegram-inbound.test.ts tests/telegram-polling-offset.test.ts",
    "test:skills": "node --experimental-strip-types --no-warnings --test tests/skill-intent.test.ts tests/skills-governance.test.ts tests/skills-scripts.test.ts",
    "test:agent-prompt": "node --experimental-strip-types --no-warnings --test tests/agent-llm-prompt.test.ts",
    "test:agent-infrastructure": "node --experimental-strip-types --no-warnings --test tests/agent-infrastructure.test.ts",
    "test:agent-capabilities": "node --experimental-strip-types --no-warnings --test tests/agent-capabilities.test.ts",
    "test:agent-registry": "node --experimental-strip-types --no-warnings --test tests/agent-registry.test.ts",
    "test:artifacts": "node --experimental-strip-types --no-warnings --test tests/artifact-contract.test.ts",
    "test:updates": "node --test tests/electron-update-errors.test.cjs",
    "test:desktop": "node --test tests/desktop-layout.test.cjs tests/desktop-preferences.test.cjs tests/electron-process-lifecycle.test.cjs tests/user-data-migration.test.cjs",
    "test:speech": "node --experimental-strip-types --no-warnings --test tests/microphone-session.test.ts",
    "test:lipsync": "node --no-warnings --test tests/lipsync-integration.test.mjs",
    "test:build-cleanup": "node --no-warnings --test tests/build-cleanup.test.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@gradio/client": "^2.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "electron-updater": "^6.7.2",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "openai": "^6.39.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.60.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.kaoz1.desktop",
    "productName": "Kaoz.1",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/standalone",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": "dist/standalone/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env.example",
        "to": "config/.env.example"
      },
      {
        "from": "build/runtime/parakeet",
        "to": "parakeet-runtime"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "artifactName": "Kaoz.1-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "eltonjr13",
        "repo": "kaoz.1"
      }
    ],
    "nsis": {
      "guid": "e2d776a6-addb-51d9-a59f-3f9eb3027011",
      "oneClick": false,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kaoz.1"
    }
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
